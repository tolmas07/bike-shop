<!-- Главный экран каталога товаров. Использует ConstraintLayout для гибкого позиционирования элементов. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:clipToPadding="false">

    <!-- Заголовок экрана "Велосипеды". -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:text="Велосипеды"
        android:textColor="#000000"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Шапка с кнопкой сортировки. -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="@id/tv_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_title">

        <!-- Кнопка переключения сортировки по цене. -->
        <ImageButton
            android:id="@+id/btn_sort"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#000000" />
    </LinearLayout>

    <!-- Горизонтальная прокрутка категорий товаров. -->
    <HorizontalScrollView
        android:id="@+id/scroll_categories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="50dp"
            android:paddingBottom="1dp">

            <!-- Кнопки категорий используют глобальный шрифт из тем. -->
            <TextView
                android:id="@+id/btn_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_line_bottom"
                android:letterSpacing="0.05"
                android:paddingBottom="4dp"
                android:text="ВСЕ"
                android:textColor="#000000"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_city"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="ГОРОДСКИЕ"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/btn_mountain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:text="ГОРНЫЕ"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/btn_electric"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.05"
                android:text="ЭЛЕКТРО"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Сетка товаров. Отображает список карточек товаров в два столбца. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_catalog"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scroll_categories" />

    <!-- Индикатор загрузки. Появляется по центру, пока данные грузятся из интернета. -->
    <ProgressBar
        android:id="@+id/progress_catalog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
