<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/iv_cart_item_image"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:scaleType="centerCrop"
        android:background="#F0F0F0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/divider" />

    <TextView
        android:id="@+id/tv_cart_item_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Product Name"
        android:textColor="#000000"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@+id/layout_quantity"
        app:layout_constraintStart_toEndOf="@id/iv_cart_item_image"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="16dp" />

    <TextView
        android:id="@+id/tv_cart_item_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="15 000 ₽"
        android:textColor="#555555"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/tv_cart_item_name"
        app:layout_constraintTop_toBottomOf="@id/tv_cart_item_name" />

    <LinearLayout
        android:id="@+id/layout_quantity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_badge_light"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintEnd_toStartOf="@+id/btn_remove_cart"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="16dp">

        <ImageView
            android:id="@+id/btn_minus"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_minus"
            app:tint="#000000" />

        <TextView
            android:id="@+id/tv_quantity"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textAlignment="center"
            android:textColor="#000000"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/btn_plus"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_plus"
            app:tint="#000000" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_remove_cart"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:alpha="0.8"
        android:src="@drawable/ic_trash"
        app:tint="#FF4D4D"
        app:layout_constraintBottom_toTopOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/iv_cart_item_image" />

</androidx.constraintlayout.widget.ConstraintLayout>
